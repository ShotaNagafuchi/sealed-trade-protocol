# Foundry deployment configuration
# Copy this file to .env and fill in your values

# RPC endpoint (Arbitrum Sepolia for testnet, Arbitrum One for mainnet)
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Deployer private key (NEVER commit the real key)
PRIVATE_KEY=0x...

# USDC contract address on target chain
USDC_ADDRESS=0x...

# Protocol owner address (Treasury admin, should be a multisig)
OWNER_ADDRESS=0x...

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=...
