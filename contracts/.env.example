# Foundry deployment configuration
# Copy this file to .env and fill in your values

# RPC endpoint (Sepolia testnet)
RPC_URL=https://rpc.sepolia.org

# Deployer private key (NEVER commit the real key)
PRIVATE_KEY=0x...

# USDC contract address on target chain
USDC_ADDRESS=0x...

# Protocol owner address (Treasury admin, should be a multisig)
OWNER_ADDRESS=0x...

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=...
